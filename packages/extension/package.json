{
  "name": "@maestro/extension",
  "displayName": "Maestro",
  "description": "Conduct a team of AI coding agents in isolated git worktrees.",
  "version": "0.0.0",
  "publisher": "prixio",
  "engines": { "vscode": "^1.90.0" },
  "categories": ["Other"],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        { "id": "maestro", "title": "Maestro", "icon": "resources/maestro.svg" }
      ]
    },
    "views": {
      "maestro": [
        { "id": "maestro.roster", "name": "Roster" }
      ]
    },
    "commands": [
      { "command": "maestro.spawnAgent", "title": "Maestro: Spawn Agent", "icon": "$(add)" },
      { "command": "maestro.launchTeam", "title": "Maestro: Launch Team", "icon": "$(organization)" },
      { "command": "maestro.openStage", "title": "Maestro: Open Stage" }
    ],
    "menus": {
      "view/title": [
        { "command": "maestro.spawnAgent", "when": "view == maestro.roster", "group": "navigation" },
        { "command": "maestro.launchTeam", "when": "view == maestro.roster", "group": "navigation" }
      ]
    },
    "configuration": {
      "title": "Maestro",
      "properties": {
        "maestro.prMode": { "type": "boolean", "default": false, "description": "Create a pull request (push branch + gh pr create) instead of a local merge." },
        "maestro.prDraft": { "type": "boolean", "default": false, "description": "Open pull requests as drafts when PR mode is on." }
      }
    }
  },
  "scripts": {
    "build": "node build.mjs",
    "watch": "node build.mjs --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "compile-integration": "tsc -p integration/tsconfig.json",
    "test:e2e": "node build.mjs && tsc -p integration/tsconfig.json && node out/integration/runTest.js"
  },
  "dependencies": {
    "@maestro/core": "workspace:*",
    "@maestro/cockpit": "workspace:*",
    "@maestro/workspace": "workspace:*",
    "@maestro/adapter-copilot": "workspace:*",
    "@maestro/adapter-acp": "workspace:*",
    "@maestro/config": "workspace:*"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.24.0",
    "glob": "^11.1.0",
    "mocha": "^11.7.6",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}

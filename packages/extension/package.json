{
  "name": "maestro-conductor",
  "displayName": "Maestro: Conduct AI Coding Agents",
  "description": "Conduct a team of AI coding agents in isolated git worktrees.",
  "version": "0.1.10",
  "icon": "media/icon.png",
  "license": "MIT",
  "publisher": "norequest",
  "repository": {
    "type": "git",
    "url": "https://github.com/norequest/maestro-vscode.git",
    "directory": "packages/extension"
  },
  "homepage": "https://github.com/norequest/maestro-vscode#readme",
  "bugs": {
    "url": "https://github.com/norequest/maestro-vscode/issues"
  },
  "keywords": [
    "ai",
    "agents",
    "github-copilot",
    "coding-agent",
    "orchestration",
    "git-worktree",
    "acp",
    "multi-agent"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "AI",
    "Machine Learning"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "maestro",
          "title": "Maestro",
          "icon": "media/maestro.svg"
        }
      ]
    },
    "views": {
      "maestro": [
        {
          "id": "maestro.home",
          "name": "Maestro",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "maestro.newAgent",
        "title": "Maestro: New Agent",
        "icon": "$(add)"
      },
      {
        "command": "maestro.spawnAgent",
        "title": "Maestro: Spawn Agent (quick)",
        "icon": "$(add)"
      },
      {
        "command": "maestro.launchTeam",
        "title": "Maestro: Launch Team",
        "icon": "$(organization)"
      },
      {
        "command": "maestro.openStage",
        "title": "Maestro: Open Conducting Board",
        "icon": "$(dashboard)"
      },
      {
        "command": "maestro.openLibrary",
        "title": "Maestro: Open Library",
        "icon": "$(library)"
      },
      {
        "command": "maestro.openAnatomy",
        "title": "Maestro: Edit Agent Anatomy",
        "icon": "$(settings-gear)"
      }
    ],
    "configuration": {
      "title": "Maestro",
      "properties": {
        "maestro.prMode": {
          "type": "boolean",
          "default": false,
          "description": "Create a pull request (push branch + gh pr create) instead of a local merge."
        },
        "maestro.prDraft": {
          "type": "boolean",
          "default": false,
          "description": "Open pull requests as drafts when PR mode is on."
        },
        "maestro.discoverPlugins": {
          "type": "boolean",
          "default": false,
          "description": "Scan installed Copilot plugins during discovery."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "node build.mjs",
    "build": "node build.mjs",
    "watch": "node build.mjs --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "compile-integration": "tsc -p integration/tsconfig.json",
    "test:e2e": "node build.mjs && tsc -p integration/tsconfig.json && node out/integration/runTest.js"
  },
  "dependencies": {
    "@maestro/core": "workspace:*",
    "@maestro/cockpit": "workspace:*",
    "@maestro/workspace": "workspace:*",
    "@maestro/adapter-copilot": "workspace:*",
    "@maestro/adapter-acp": "workspace:*",
    "@maestro/config": "workspace:*"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.24.0",
    "glob": "^11.1.0",
    "mocha": "^11.7.6",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}

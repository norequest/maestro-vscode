{
  "name": "hallucinate",
  "displayName": "Hallucinate: Run AI Coding Agents",
  "description": "Run a team of AI coding agents in isolated git worktrees.",
  "version": "0.1.10",
  "icon": "media/icon.png",
  "license": "MIT",
  "publisher": "norequest",
  "repository": {
    "type": "git",
    "url": "https://github.com/norequest/hallucinate.git",
    "directory": "packages/extension"
  },
  "homepage": "https://github.com/norequest/hallucinate#readme",
  "bugs": {
    "url": "https://github.com/norequest/hallucinate/issues"
  },
  "keywords": [
    "ai",
    "agents",
    "github-copilot",
    "coding-agent",
    "coordination",
    "git-worktree",
    "acp",
    "multi-agent"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "AI",
    "Machine Learning"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "hallucinate",
          "title": "Hallucinate",
          "icon": "media/hallucinate.svg"
        }
      ]
    },
    "views": {
      "hallucinate": [
        {
          "id": "hallucinate.home",
          "name": "Hallucinate",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "hallucinate.newAgent",
        "title": "Hallucinate: New Agent",
        "icon": "$(add)"
      },
      {
        "command": "hallucinate.spawnAgent",
        "title": "Hallucinate: Spawn Agent (quick)",
        "icon": "$(add)"
      },
      {
        "command": "hallucinate.launchTeam",
        "title": "Hallucinate: Launch Team",
        "icon": "$(organization)"
      },
      {
        "command": "hallucinate.openStage",
        "title": "Hallucinate: Open Board",
        "icon": "$(dashboard)"
      },
      {
        "command": "hallucinate.openLibrary",
        "title": "Hallucinate: Open Library",
        "icon": "$(library)"
      },
      {
        "command": "hallucinate.openAnatomy",
        "title": "Hallucinate: Edit Agent Anatomy",
        "icon": "$(settings-gear)"
      }
    ],
    "configuration": {
      "title": "Hallucinate",
      "properties": {
        "hallucinate.prMode": {
          "type": "boolean",
          "default": false,
          "description": "Create a pull request (push branch + gh pr create) instead of a local merge."
        },
        "hallucinate.prDraft": {
          "type": "boolean",
          "default": false,
          "description": "Open pull requests as drafts when PR mode is on."
        },
        "hallucinate.discoverPlugins": {
          "type": "boolean",
          "default": false,
          "description": "Scan installed Copilot plugins during discovery."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "node build.mjs",
    "build": "node build.mjs",
    "watch": "node build.mjs --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "compile-integration": "tsc -p integration/tsconfig.json",
    "test:e2e": "node build.mjs && tsc -p integration/tsconfig.json && node out/integration/runTest.js"
  },
  "dependencies": {
    "@hallucinate/core": "workspace:*",
    "@hallucinate/cockpit": "workspace:*",
    "@hallucinate/workspace": "workspace:*",
    "@hallucinate/adapter-copilot": "workspace:*",
    "@hallucinate/adapter-acp": "workspace:*",
    "@hallucinate/config": "workspace:*"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.24.0",
    "glob": "^11.1.0",
    "mocha": "^11.7.6",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}

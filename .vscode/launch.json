{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Maestro (dogfood on this repo)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "${workspaceFolder}",
        "--extensionDevelopmentPath=${workspaceFolder}/packages/extension"
      ],
      "outFiles": ["${workspaceFolder}/packages/extension/dist/**/*.js"],
      "preLaunchTask": "build maestro"
    }
  ]
}
